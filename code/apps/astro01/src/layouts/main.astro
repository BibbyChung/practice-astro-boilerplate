---
import Layout from '~/layouts/layout.astro'
// import Menu from '~/lib/components/menu.svelte'
import { MenuComponent } from '~/lib/components/ng/menu.component'

type Props = {
  title: string
}
const props = Astro.props
---

<Layout {...props}>
  <main class="p-8">
    <div class="w-full">
      <!-- <Menu client:load /> -->
      <MenuComponent client:load />
    </div>
    <div class="mt-12 flex w-full flex-col items-start">
      <slot />
    </div>
  </main>
</Layout>
